{
  "name": "prague",
  "private": true,
  "packageManager": "pnpm@10.28.1",
  "scripts": {
    "dev": "npm-run-all --parallel dev:web dev:convex",
    "dev:web": "pnpm --filter web dev",
    "dev:convex": "convex dev",
    "build": "pnpm --filter web build",
    "lint": "oxlint apps/web/src convex && eslint convex",
    "format": "oxfmt apps/web/src convex",
    "format:check": "oxfmt --check apps/web/src convex",
    "type-check": "pnpm --filter web type-check",
    "lint:all": "pnpm format:check && pnpm lint && pnpm type-check",
    "deploy:convex": "convex deploy"
  },
  "devDependencies": {
    "@convex-dev/eslint-plugin": "^1.1.1",
    "@types/node": "^25.3.5",
    "convex": "^1.32.0",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0",
    "typescript-eslint": "^8.56.1",
    "zod": "^4.3.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "peerDependencyRules": {
      "allowedVersions": {
        "@tailwindcss/vite>vite": ">=8.0.0-0"
      }
    }
  }
}
